FROM ollama/ollama:latest

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy custom configuration if needed
# COPY ollama.conf /etc/ollama/ollama.conf

# Expose the Ollama port
EXPOSE 11434

# Set environment variables for Gemma 4
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_MODELS=/root/.ollama/models

# Create models directory
RUN mkdir -p /root/.ollama/models

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

# Default command
CMD ["serve"]

# Pre-pull Gemma 4 model on build (optional - increases image size)
# RUN ollama serve & sleep 5 && ollama pull gemma4:latest && pkill ollama