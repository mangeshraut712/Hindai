# Hind AI Environment Configuration
# Copy this file to .env.local and fill in your values

# ==========================================
# REQUIRED: Gemma 4 API access via Google AI Studio
# Get your API key from: https://aistudio.google.com/app/apikey
# ==========================================
GEMMA_API_KEY=your_gemma_api_key_here
# Alternative supported names in production:
# GEMINI_API_KEY=your_google_ai_studio_key_here
# GOOGLE_API_KEY=your_google_ai_studio_key_here
GEMMA_MODEL=gemma-4-31b-it

# ==========================================
# REQUIRED: Upstash Redis (for rate limiting & caching)
# Optional in development because the app falls back to an in-memory cache.
# Recommended on Vercel for shared cache + rate limiting across invocations.
# Get from: https://upstash.com/
# ==========================================
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Note:
# KAGGLE_API_TOKEN is not required for the deployed Next.js app runtime.
# It is only needed for Kaggle CLI/model management workflows.

# ==========================================
# Optional: Supabase (for data storage)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==========================================
# Optional: Analytics & Monitoring
# ==========================================
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id
