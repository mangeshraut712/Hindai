# Hind AI – Environment Variables
# Copy to .env.local for development

# ─────────────── Local Ollama (development) ───────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:latest

# ─────────────── Cloud Ollama (optional, for Vercel) ───────────────
# OLLAMA_CLOUD_URL=https://your-ollama-cloud.example.com
# OLLAMA_API_KEY=your_api_key_here

# ─────────────── Google Gemma API (production) ───────────────
# Free access via Google AI Studio: https://aistudio.google.com/app/apikey
# Available models: gemma-3-27b-it, gemma-3-12b-it, gemma-3-4b-it, gemma-3-1b-it
# Note: gemma-4 models are supported in code but may not be available via Google API yet
GEMINI_API_KEY=
GEMMA_MODEL=gemma-3-27b-it

# ─────────────── Kaggle (model access) ───────────────
# KAGGLE_API_TOKEN=

# ─────────────── Upstash Redis (caching + rate limiting) ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────── Supabase (optional persistence) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────── Site URL (canonical link) ───────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────── Analytics (optional) ───────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
